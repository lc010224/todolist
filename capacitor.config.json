{
  "$schema": "https://json.schemastore.org/capacitor.config.json",
  "appId": "com.todo.app",
  "appName": "待办清单",
  "webDir": "out",
  "server": {
    "androidScheme": "http"
  },
  "android": {
    "backgroundColor": "#ffffff",
    "allowMixedContent": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "backgroundColor": "#ffffff",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    }
  }
}
